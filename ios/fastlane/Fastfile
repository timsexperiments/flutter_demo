default_platform(:ios)

platform :ios do
  before_all do
    # Only run the global API key setup if we are in CI (where key_content exists)
    if ENV["APP_STORE_CONNECT_API_KEY_KEY"] && !ENV["APP_STORE_CONNECT_API_KEY_KEY"].empty?
      app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
        key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"]
      )
    end
  end

  desc "Locally generate code signing certificates using the API Key"
  lane :generate_certs do
    unless ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"] && ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"] && ENV["APP_STORE_CONNECT_API_KEY_FILE"]
      UI.user_error!("Missing API Key environment variables! Please export APP_STORE_CONNECT_API_KEY_KEY_ID, APP_STORE_CONNECT_API_KEY_ISSUER_ID, and APP_STORE_CONNECT_API_KEY_FILE before running this command.")
    end

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_FILE"],
      in_house: false
    )
    match(type: "appstore", api_key: api_key)
  end

  desc "Push a new beta build to TestFlight PR group"
  lane :pr_build do
    setup_ci
    match(type: "appstore", readonly: true)
    update_code_signing_settings(
      use_automatic_signing: false, 
      path: "Runner.xcodeproj",
      team_id: "9DS32XJMBD",
      profile_name: "match AppStore com.timothyaltemus.placeholder",
      code_sign_identity: "Apple Distribution"
    )

    build_app(
      scheme: "Runner",
      export_method: "app-store"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: "PR Build \#{ENV['GITHUB_PR_NUMBER']} - \#{ENV['GITHUB_SHA']}"
    )
  end

  desc "Push a new beta build to TestFlight Main group"
  lane :beta_dev do
    setup_ci
    match(type: "appstore", readonly: true)
    update_code_signing_settings(
      use_automatic_signing: false, 
      path: "Runner.xcodeproj",
      team_id: "9DS32XJMBD",
      profile_name: "match AppStore com.timothyaltemus.placeholder",
      code_sign_identity: "Apple Distribution"
    )
    
    build_app(
      scheme: "Runner",
      export_method: "app-store"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: "Main Branch Build - \#{ENV['GITHUB_SHA']}"
    )
  end

  desc "Push a new release build to TestFlight"
  lane :release_prod do
    setup_ci
    match(type: "appstore", readonly: true)
    update_code_signing_settings(
      use_automatic_signing: false, 
      path: "Runner.xcodeproj",
      team_id: "9DS32XJMBD",
      profile_name: "match AppStore com.timothyaltemus.placeholder"
    )
    
    build_app(
      scheme: "Runner",
      export_method: "app-store"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: "Release \#{ENV['GITHUB_REF_NAME']}"
    )
  end
end
